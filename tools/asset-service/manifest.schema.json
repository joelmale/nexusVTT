{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "version": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "totalAssets": {
      "type": "integer"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "thumbnail": {
            "type": "string"
          },
          "fullImage": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          },
          "sha256": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "enum": ["base", "tmt", "user"]
          },
          "dimensions": {
            "type": "object",
            "properties": {
              "width": { "type": "integer" },
              "height": { "type": "integer" }
            }
          },
          "sourcePath": {
            "type": "string",
            "description": "Path of the primary source file within the release archive, relative to its staging root. Used by tools/tmt-ingest/sync.mjs to diff releases."
          },
          "duplicatePaths": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Additional source paths that hashed identically to this asset and were deduped onto it."
          },
          "removed": {
            "type": "boolean",
            "description": "Tombstone flag set by sync.mjs when this asset's source file(s) are absent from a later release. The entry is kept (not deleted) so existing references (e.g. copied Token.image strings) are never broken; removed assets are excluded from library listings by default."
          },
          "removedInRelease": {
            "type": "string",
            "description": "Release tag in which this asset was first observed as removed. Only present when removed=true."
          }
        },
        "required": [
          "id",
          "name",
          "category",
          "tags",
          "thumbnail",
          "fullImage",
          "size",
          "sha256",
          "source"
        ]
      }
    }
  },
  "required": [
    "version",
    "generatedAt",
    "totalAssets",
    "categories",
    "assets"
  ]
}
