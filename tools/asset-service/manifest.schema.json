{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "version": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "totalAssets": {
      "type": "integer"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "thumbnail": {
            "type": "string"
          },
          "fullImage": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          },
          "sha256": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "enum": ["base", "tmt", "user"]
          },
          "dimensions": {
            "type": "object",
            "properties": {
              "width": { "type": "integer" },
              "height": { "type": "integer" }
            }
          }
        },
        "required": [
          "id",
          "name",
          "category",
          "tags",
          "thumbnail",
          "fullImage",
          "size",
          "sha256",
          "source"
        ]
      }
    }
  },
  "required": [
    "version",
    "generatedAt",
    "totalAssets",
    "categories",
    "assets"
  ]
}
