# Nexus VTT Environment Configuration
# Copy this file to .env and fill in your values before starting.
# Variables marked REQUIRED must be set; others have sensible defaults.

# ====================
# Application
# ====================
NODE_ENV=development           # development | production
# PORT — read by the BACKEND server (default 5001). Never set to the vite port (5173):
# doing so silently rebinds the backend and breaks game creation. Asset service uses 5003.
# PORT=5001
WS_PORT=5001                   # Backend / WebSocket port

# ====================
# Development / Feature Flags
# ====================
# Unified dev-mode switch. Gates dev-only behaviour: mock campaign/character
# seeding (POST /api/dev/populate-mock-data), the lobby dev tools, and verbose
# delta-sync resync logging in the browser console.
#   DEV_MODE      → server-side (default: NODE_ENV !== 'production')
#   VITE_DEV_MODE → client-side (default: import.meta.env.DEV)
# Leave unset to inherit the build mode, or set 'true'/'false' to force it.
# Does NOT affect security (session secrets, secure cookies, CORS) — those stay
# tied to NODE_ENV.
DEV_MODE=true
VITE_DEV_MODE=true

# Content-hash-chained delta-sync (client). Default OFF — the client sends the
# legacy full snapshot. Set 'true' to send JSON-patch deltas with ack/resync
# reconciliation, then watch GET /api/metrics/delta-sync (go criterion:
# integrity-mismatch === 0 and a low steady-state resyncRate).
VITE_DELTA_SYNC=false

# ====================
# URLs & CORS
# ====================
FRONTEND_URL=http://localhost:5173
VITE_WS_URL=ws://localhost:5001/ws
DOMAIN=nexus-vtt.local
# Comma-separated list of allowed CORS origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ====================
# Security  (REQUIRED in production — change all defaults)
# ====================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SESSION_SECRET=your-session-secret-change-this-in-production
ADMIN_PASSWORD=admin-password-change-this

# Controls whether the session cookie carries the Secure flag.
# In production this defaults to true (cookies only sent over HTTPS).
# Set to false ONLY in non-TLS local environments.
# Do NOT confuse with FORCE_HTTPS — that variable no longer exists.
SECURE_COOKIES=true

# ====================
# Database  (REQUIRED)
# ====================
DATABASE_URL=postgresql://nexus:password@localhost:5432/nexus

# Used by the postgres service in docker-compose
POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change-this-password

# ====================
# Redis  (REQUIRED)
# ====================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=change-this-redis-password

# ====================
# OAuth — Google  (REQUIRED for Google login)
# Get credentials: https://console.cloud.google.com/apis/credentials
# ====================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Must be an absolute HTTPS URL in production.
# Register this exact URL as an authorised redirect URI in Google Cloud Console.
GOOGLE_CALLBACK_URL=http://localhost:5001/auth/google/callback
# Production example:
# GOOGLE_CALLBACK_URL=https://app.nexusvtt.com/auth/google/callback

# ====================
# OAuth — Discord  (REQUIRED for Discord login)
# Get credentials: https://discord.com/developers/applications
# ====================
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Must be an absolute HTTPS URL in production.
# Register this exact URL as a redirect URI in your Discord application.
DISCORD_CALLBACK_URL=http://localhost:5001/auth/discord/callback
# Production example:
# DISCORD_CALLBACK_URL=https://app.nexusvtt.com/auth/discord/callback

# ====================
# Docker & Deployment
# ====================
# Container image registry prefix
IMAGE_PREFIX=ghcr.io/joelmale/nexusvtt
# Image tag to deploy (CI sets this automatically on master; defaults to 'latest')
VERSION=latest
# Docker network your reverse proxy (Nginx Proxy Manager, Traefik, etc.) is attached to.
# The frontend container joins this network so the proxy can reach it.
PROXY_NETWORK=homelab-net

# ====================
# Asset Management
# ====================
ASSETS_PATH=./static-assets/assets
CACHE_MAX_AGE=86400
MAX_UPLOAD_SIZE=50
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,svg,mp3,ogg,wav

# Standalone asset service (services/asset-service) — must be a distinct
# port from WS_PORT above, or the VTT will self-proxy / fail to bind.
ASSET_API_URL=http://localhost:5003
# Shared secret the VTT injects when proxying authenticated writes
# (upload/delete) to the asset service. Must match the asset service's
# own ASSET_SERVICE_SECRET. No dev fallback in production.
ASSET_SERVICE_SECRET=

# ====================
# Performance & Limits
# ====================
MAX_CONNECTIONS_PER_ROOM=50
WS_HEARTBEAT_INTERVAL=30000
SESSION_TIMEOUT=1440
RATE_LIMIT_RPM=100

# ====================
# External Services  (all optional)
# ====================
SENTRY_DSN=
ANALYTICS_ID=
DISCORD_WEBHOOK_URL=

# ====================
# Development Only
# ====================
HOT_RELOAD=true
DEBUG=false
USE_MOCK_DATA=false
ENABLE_DEV_TOOLS=true

# ====================
# Feature Flags
# ====================
FEATURE_INITIATIVE_TRACKER=false
FEATURE_CHAT_SYSTEM=false
FEATURE_SOUND_EFFECTS=false
FEATURE_ADVANCED_TOKENS=false
FEATURE_FOG_OF_WAR=false
FEATURE_DYNAMIC_LIGHTING=false
USE_MESSAGEPACK=true           # Enable binary WebSocket encoding (MessagePack)
VITE_USE_MESSAGEPACK=true      # Enable binary WebSocket decoding in frontend
# Content-hash-chained delta-sync (PR-3). Default OFF (rollback switch): client
# sends the legacy full snapshot and ignores ack/resync. Set 'true' to enable
# tagged-full/patch uploads + ack/resync/timeout reconciliation.
VITE_DELTA_SYNC=false

# ====================
# Testing
# ====================
TEST_MODE=false
TEST_USER_ID=test-user-123
TEST_ROOM_CODE=TEST

# ====================
# Monitoring & Logging
# ====================
HEALTH_CHECK_PATH=/health
METRICS_PATH=/metrics
LOG_LEVEL=info                 # error | warn | info | debug | trace
LOG_TO_FILE=false
LOG_FILE_PATH=./logs/nexus.log
